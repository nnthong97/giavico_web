{
  "buildCommand": "npx nx build dashboard --configuration=production",
  "outputDirectory": "dist/apps/dashboard",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/server/server.mjs" }
  ],
  "functions": {
    "dist/apps/dashboard/server/server.mjs": {
      "runtime": "nodejs20.x",
      "maxDuration": 10
    }
  },
  "env": {
    "DATABASE_URL": "@database_url"
  }
}
