{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx nx build dashboard --configuration=production",
  "outputDirectory": "dist/apps/dashboard/browser",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/gemini.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
